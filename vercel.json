{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/vente", "destination": "/vente.html" },
    { "source": "/download", "destination": "/kam-ai-first-toolkit.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/vente",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    },
    {
      "source": "/download",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"kam-ai-first-toolkit.html\"" },
        { "key": "Content-Type", "value": "application/octet-stream" }
      ]
    }
  ],
  "functions": {
    "api/chat.ts": { "maxDuration": 30 },
    "api/validate-code.ts": { "maxDuration": 5 }
  }
}
